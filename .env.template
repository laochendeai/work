# ==================== 应用配置 ====================
# 应用名称
APP_NAME=智能设计营销系统
APP_VERSION=3.0

# Python环境
PYTHONUNBUFFERED=1
PYTHONPATH=/app

# ==================== 运行模式 ====================
# 队列模式（0=否，1=是）
QUEUE_MODE=0

# Web服务器配置
HOST=0.0.0.0
PORT=8000

# ==================== 数据库配置 ====================
# SQLite数据库路径
DATABASE_PATH=/app/data/marketing.db

# ==================== Redis配置（如果使用） ====================
# REDIS_URL=redis://localhost:6379
REDIS_URL=redis://redis:6379

# ==================== 邮件配置 ====================
# SMTP服务器配置
EMAIL_SMTP_SERVER=smtp.qq.com
EMAIL_SMTP_PORT=587
EMAIL_SENDER_EMAIL=your_email@qq.com
EMAIL_SENDER_PASSWORD=your_password
EMAIL_SENDER_NAME=设计营销助手

# ==================== AI处理配置 ====================
# AI处理启用（0=否，1=是）
AI_ENABLED=0
AI_PROVIDER=openai
AI_API_KEY=sk-your-api-key
AI_MODEL=gpt-3.5-turbo
AI_BASE_URL=

# ==================== 爬虫配置 ====================
# 网络配置
SCRAPER_CONCURRENCY=10
SCRAPER_TIMEOUT=30
SCRAPER_RETRY_ATTEMPTS=3

# 延迟配置（秒）
SCRAPER_DELAY_MIN=3
SCRAPER_DELAY_MAX=8

# ==================== 日志配置 ====================
# 日志级别 (DEBUG, INFO, WARNING, ERROR, CRITICAL)
LOG_LEVEL=INFO
LOG_FILE=/app/logs/marketing.log

# ==================== 监控配置 ====================
# Prometheus指标
METRICS_ENABLED=1
METRICS_PORT=9090

# ==================== 安全配置 ====================
# JWT密钥（如果使用）
JWT_SECRET=your-secret-key

# CORS配置
CORS_ORIGINS=http://localhost:3000,http://localhost:8080